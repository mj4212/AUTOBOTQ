# Environment Configuration for AUTOBOTQ
# Copy this file to .env and fill in your actual values

# Node Environment
NODE_ENV=development
LOG_LEVEL=info

# =====================================
# NOTION API CONFIGURATION (Required)
# =====================================
# Get from: https://www.notion.so/my-integrations
# 1. Create a new integration
# 2. Copy the "Internal Integration Token"
NOTION_API_KEY=your_notion_api_key_here

# Get your Notion Database ID:
# 1. Open your Notion database
# 2. Click Share → Copy the URL
# 3. Extract the ID from the URL (long alphanumeric string)
NOTION_DATABASE_ID=your_notion_database_id_here

# =====================================
# FXMACRODATA API CONFIGURATION (Required)
# =====================================
# Get from your fxmacrodata.com account
FXMACRODATA_API_KEY=your_fxmacrodata_api_key_here

# Optional: API base URL (defaults to production)
FXMACRODATA_BASE_URL=https://api.fxmacrodata.com/api/v1

# =====================================
# POLLING & TIMING CONFIGURATION
# =====================================
# How often to check for new data (in milliseconds)
# Default: 300000 (5 minutes)
POLL_INTERVAL=300000

# Only fetch data newer than this many minutes
# Default: 60 (only data less than 1 hour old)
MAX_AGE_MINUTES=60

# =====================================
# BATCH PROCESSING CONFIGURATION
# =====================================
# How many records to push to Notion at once
# Default: 25 (Notion API rate limits)
BATCH_SIZE=25

# Delay between batches in milliseconds
# Default: 10000 (10 seconds)
BATCH_TIMEOUT=10000

# =====================================
# API TIMEOUT & RETRY CONFIGURATION
# =====================================
# Timeout for API requests in milliseconds
FXMACRODATA_TIMEOUT=30000

# Number of retry attempts for failed requests
FXMACRODATA_RETRY_ATTEMPTS=3

# Delay between retries in milliseconds
FXMACRODATA_RETRY_DELAY=2000

# Max retries for general operations
MAX_RETRIES=3

# Retry delay for general operations
RETRY_DELAY=5000
